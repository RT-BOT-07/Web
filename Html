<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RT Smart Portfolio</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <style>
        /* --- HIGH-END THEMES WITH MATCHING FONTS --- */
        :root {
            --bg: radial-gradient(circle, #0f172a, #020617);
            --glass: rgba(15, 23, 42, 0.7);
            --primary: #38bdf8;
            --text: #f8fafc;
            --glow: 0 0 15px rgba(56, 189, 248, 0.4);
        }

        .theme-cyber { 
            --bg: linear-gradient(135deg, #020617 0%, #0c4a6e 100%); 
            --primary: #22d3ee; --text: #e0f2fe; --glass: rgba(8, 47, 73, 0.7); 
        }
       .theme-vulcan { 
            --bg: linear-gradient(160deg, #020617 0%, #4c1d95 100%); 
            --primary: #a78bfa; 
            --text: #f5f3ff; 
            --glass: rgba(12, 10, 29, 0.7); 
            --glow: 0 0 25px rgba(167, 139, 250, 0.5);
        }

        .theme-aurora { 
            --bg: radial-gradient(circle at top, #064e3b, #020617); 
            --primary: #4ade80; --text: #dcfce7; --glass: rgba(6, 78, 59, 0.7); 
        }
        .theme-midnight { 
            --bg: linear-gradient(to bottom, #000000, #1a1a1a); 
            --primary: #ffffff; --text: #ffffff; --glass: rgba(30, 30, 30, 0.8); 
        }
        .theme-gold { 
            --bg: linear-gradient(135deg, #1c1917 0%, #44403c 100%); 
            --primary: #fbbf24; --text: #fef3c7; --glass: rgba(41, 37, 36, 0.8); 
        }

        * { margin: 0; padding: 0; box-sizing: border-box; font-family: 'Poppins', sans-serif; }
        body { background: var(--bg); color: var(--text); height: 100vh; overflow: hidden; display: flex; align-items: center; justify-content: center; transition: 0.5s ease; }

        /* --- CARD & LAYOUT --- */
        .card {
            background: var(--glass); backdrop-filter: blur(25px);
            width: 92%; max-width: 400px; padding: 25px; border-radius: 40px;
            border: 1px solid rgba(255,255,255,0.1); display: none;
            box-shadow: 0 25px 50px rgba(0,0,0,0.6); position: relative;
        }

        .section-active { display: flex; flex-direction: column; animation: slideUp 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards; }
        @keyframes slideUp { from { opacity: 0; transform: translateY(50px) scale(0.9); } to { opacity: 1; transform: translateY(0) scale(1); } }

        .section-back { display: flex; flex-direction: column; animation: slideDown 0.6s cubic-bezier(0.34, 1.56, 0.64, 1) forwards; }
        @keyframes slideDown { from { opacity: 0; transform: translateY(-50px) scale(0.9); } to { opacity: 1; transform: translateY(0) scale(1); } }

        /* --- FIXED AI UI AREA (MOVING DOWN) --- */
        #ai-tool-area { 
            height: calc(100vh - 120px); 
            margin-top: 80px; 
            margin-bottom: 20px;
            justify-content: space-between; 
        }
        
        #chatBox { flex-grow: 1; overflow-y: auto; padding: 10px; margin: 15px 0; background: rgba(0,0,0,0.2); border-radius: 25px; border: 1px solid rgba(255,255,255,0.05); }

        .bubble { margin: 10px 0; padding: 12px 18px; border-radius: 20px; font-size: 13.5px; max-width: 85%; line-height: 1.5; box-shadow: 0 4px 10px rgba(0,0,0,0.2); }
        .ai-msg { background: var(--glass); color: var(--text); border-bottom-left-radius: 2px; align-self: flex-start; border: 1px solid var(--primary); }
        .user-msg { background: var(--primary); color: #000; align-self: flex-end; border-bottom-right-radius: 2px; font-weight: 600; margin-left: auto; }

        .top-nav { position: absolute; top: 0; width: 100%; display: flex; justify-content: space-between; padding: 20px 25px; z-index: 1000; visibility: hidden; opacity: 0; }
        
        .nav-icon { font-size: 24px; cursor: pointer; color: var(--primary); transition: 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275); filter: drop-shadow(0 0 5px var(--primary)); }
        .nav-icon:active { transform: rotate(180deg); }
        
        /* Smooth Palette Animation */
        .fa-palette { animation: palettePulse 4s infinite ease-in-out; }
        @keyframes palettePulse { 
            0% { transform: scale(1) rotate(0); filter: drop-shadow(0 0 2px var(--primary)); }
            50% { transform: scale(1.2) rotate(45deg); filter: drop-shadow(0 0 15px var(--primary)); }
            100% { transform: scale(1) rotate(0); filter: drop-shadow(0 0 2px var(--primary)); }
        }

        #sideMenu { position: fixed; top: 70px; left: 20px; background: var(--glass); padding: 15px; border-radius: 20px; display: none; z-index: 2000; border: 1px solid var(--primary); }
        #sideMenu a { display: block; color: var(--text); padding: 10px 20px; text-decoration: none; font-weight: bold; transition: 0.3s; }
        #sideMenu a:hover { color: var(--primary); transform: translateX(5px); }

        .btn { width: 100%; padding: 16px; border-radius: 18px; border: none; cursor: pointer; font-weight: 800; background: var(--primary); color: #000; transition: 0.3s; }
        .btn:active { transform: scale(0.95); }

        /* Round Voice Button */
        .mic-btn { 
            width: 55px; height: 55px; border-radius: 50%; 
            background: var(--glass); border: 2px solid var(--primary); 
            color: var(--primary); display: flex; align-items: center; 
            justify-content: center; font-size: 20px; cursor: pointer; 
            transition: 0.4s; flex-shrink: 0;
        }
        .mic-btn:hover { background: var(--primary); color: #000; box-shadow: 0 0 20px var(--primary); }

        #voice-page { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: var(--bg); z-index: 5000; display: none; flex-direction: column; align-items: center; justify-content: center; }
        
        .voice-circle { 
            width: 140px; height: 140px; background: var(--glass); border: 4px solid var(--primary); 
            border-radius: 50%; display: flex; align-items: center; justify-content: center; 
            transition: 0.3s; position: relative;
        }
        .voice-active { animation: voicePulse 0.5s infinite alternate; }
        @keyframes voicePulse {
            0% { transform: scale(1); box-shadow: 0 0 10px var(--primary); }
            100% { transform: scale(1.15); box-shadow: 0 0 40px var(--primary); }
        }
        
        .voice-circle i { font-size: 50px; color: var(--primary); }
        
        .input-box { width: 100%; padding: 16px; border-radius: 15px; border: none; background: rgba(255,255,255,0.05); color: #fff; text-align: center; border: 1px solid rgba(255,255,255,0.1); outline: none; }
    </style>
</head>
<body class="theme-cyber">

    <div id="voice-page">
        <div class="voice-circle" id="micPulse">
            <i class="fas fa-microphone"></i>
        </div>
        <div id="vText" style="margin-top: 40px; font-size: 22px; font-weight: bold; color: var(--primary); text-align: center; padding: 0 20px;">Listening...</div>
        <button class="btn" style="width: auto; margin-top: 60px; background: transparent; border: 1px solid red; color: red; padding: 10px 40px;" onclick="stopVoice()">CANCEL</button>
    </div>

    <div class="top-nav" id="appHeader">
        <i class="fas fa-bars nav-icon" id="menuIcon" onclick="toggleMenu(event)"></i>
        <div style="font-size: 24px; font-weight: 900; color: var(--primary);" class="rt-logo">RT</div>
        <i class="fas fa-palette nav-icon" onclick="cycleTheme()"></i>
    </div>

    <div id="sideMenu">
        <a onclick="showSection('profile')">HOME</a>
        <a onclick="showSection('ai')">AI TOOL</a>
        <a onclick="showSection('info')">INFO</a>
    </div>

    <div id="password-page" class="card section-active">
        <div style="font-size: 50px; color: var(--primary); margin-bottom: 20px;"><i class="fas fa-fingerprint"></i></div>
        <h2>Unlock RT Systems</h2>
        <input type="password" id="passInput" class="input-box" placeholder="Access Key" style="margin-top: 20px;">
        <button class="btn" style="margin-top: 20px;" onclick="handleUnlock()">IDENTIFY</button>
    </div>

    <div id="main-profile" class="card">
        <div style="width: 100px; height: 100px; background: var(--primary); border-radius: 50%; margin: 0 auto 20px; display: flex; align-items: center; justify-content: center; font-size: 40px; color: #000; font-weight: bold;">RT</div>
        <h1>RT Gamerz</h1>
        <p style="opacity: 0.6; margin-bottom: 20px;">B.Sc MPCS Developer</p>
        <button class="btn" onclick="showSection('info')">MY DATA</button>
        <button class="btn" onclick="showSection('ai')" style="background: transparent; border: 2px solid var(--primary); color: var(--primary); margin-top: 15px;">AI SYSTEM</button>
    </div>

    <div id="ai-tool-area" class="card">
        <h3 style="color: var(--primary);">RT Intelligent AI</h3>
        <div id="chatBox" style="display: flex; flex-direction: column;">
            <div class="bubble ai-msg">Welcome RT. How are you today?</div>
        </div>
        <input type="text" id="chatInput" class="input-box" placeholder="Ask anything...">
        <div style="display: flex; gap: 15px; margin-top: 15px; align-items: center;">
            <div class="mic-btn" onclick="startVoice()"><i class="fas fa-microphone"></i></div>
            <button class="btn" onclick="handleSend(false)">SEND</button>
        </div>
    </div>

    <div id="info-section" class="card">
        <h2 style="color: var(--primary); margin-bottom: 20px;">Identity Info</h2>
        <div style="text-align: left; padding: 15px; background: rgba(255,255,255,0.03); border-radius: 20px;">
            <p>NAME: <span style="float: right; color: var(--primary);">RT</span></p><br>
            <p>COURSE: <span style="float: right; color: var(--primary);">B.Sc MPCS</span></p><br>
            <p>AGE: <span style="float: right; color: var(--primary);">18</span></p>
        </div>
        <button class="btn" style="margin-top: 20px; background: transparent; border: 1px solid var(--primary); color: var(--primary);" onclick="showSection('profile')">BACK</button>
    </div>

    <script>
        const PASS = "RT";
        const themes = ['theme-cyber', 'theme-vulcan', 'theme-aurora', 'theme-midnight', 'theme-gold'];
        let currentT = 0;
        let recognition;
        let silenceTimer;
        let isVoiceMode = false;

        const aiResponses = {
            greetings: ["Namaste RT! Ela unnavu?", "Hi RT! Systems online and ready.", "Hello Master RT! Em help cheyali?", "Greetings RT. How's the coding going?"],
            status: ["I am doing great! Working smoothly on your device.", "All systems are green. Performance is 100%.", "Everything is perfect here."],
            identity: ["I am RT's personal intelligence tool, built for speed.", "I am your AI assistant, specialized in BSc MPCS topics.", "You built me to be the best! I am RT-AI."],
            default: ["That's interesting! Tell me more, RT.", "I'm processing that. Can you explain further?", "Got it. Anything else you want to discuss?", "Interesting point, RT."]
        };

        // --- NEW WEATHER LOGIC ---
        function getCoords() {
            return new Promise((resolve) => {
                if (!navigator.geolocation) resolve(null);
                navigator.geolocation.getCurrentPosition(
                    (pos) => resolve(`${pos.coords.latitude},${pos.coords.longitude}`),
                    () => resolve(null)
                );
            });
        }

        async function fetchWeather(location = "") {
            try {
                const response = await fetch(`https://wttr.in/${location}?format=3`);
                const data = await response.text();
                if (data.includes("Unknown location")) return "Sari ayina location cheppu RT!";
                return `Ippudu mee daggara: ${data} Master RT!`;
            } catch (e) {
                return "Weather server down undi RT.";
            }
        }

        function cycleTheme() {
            document.body.classList.remove(themes[currentT]);
            currentT = (currentT + 1) % themes.length;
            document.body.classList.add(themes[currentT]);
        }

        function toggleMenu(e) { 
            e.stopPropagation(); 
            const m = document.getElementById('sideMenu'); 
            m.style.display = (m.style.display === 'block') ? 'none' : 'block'; 
        }
        
        window.onclick = () => { document.getElementById('sideMenu').style.display = 'none'; };

        function showSection(id) {
            const sections = ['password-page', 'main-profile', 'ai-tool-area', 'info-section'];
            sections.forEach(s => {
                document.getElementById(s).classList.remove('section-active', 'section-back');
            });

            const target = (id === 'profile') ? 'main-profile' : (id === 'ai' ? 'ai-tool-area' : 'info-section');
            document.getElementById(target).classList.add(id === 'profile' ? 'section-back' : 'section-active');
        }

        if ('webkitSpeechRecognition' in window) {
            recognition = new webkitSpeechRecognition();
            recognition.continuous = true;
            recognition.interimResults = true;
            recognition.lang = 'en-US';

            recognition.onresult = (event) => {
                let trans = "";
                const mic = document.getElementById('micPulse');
                mic.classList.add('voice-active');

                for (let i = event.resultIndex; i < event.results.length; i++) trans += event.results[i][0].transcript;
                document.getElementById('vText').innerText = trans;
                document.getElementById('chatInput').value = trans;

                clearTimeout(silenceTimer);
                silenceTimer = setTimeout(() => { 
                    if (trans.trim() !== "") { 
                        handleSend(true);
                        stopVoice(); 
                    } 
                    mic.classList.remove('voice-active');
                }, 2000);
            };
            
            recognition.onend = () => {
                document.getElementById('micPulse').classList.remove('voice-active');
            };
        }

        function startVoice() { 
            isVoiceMode = true;
            document.getElementById('voice-page').style.display = 'flex'; 
            recognition.start(); 
        }
        
        function stopVoice() { 
            document.getElementById('voice-page').style.display = 'none'; 
            if(recognition) recognition.stop(); 
        }

        function speakText(text) {
            if (!isVoiceMode) return;
            const speech = new SpeechSynthesisUtterance(text);
            speech.lang = 'en-IN';
            speech.rate = 1.0;
            window.speechSynthesis.speak(speech);
            isVoiceMode = false;
        }

        // --- UPDATED HANDLE SEND WITH WEATHER ---
        async function handleSend(fromVoice = false) {
            const input = document.getElementById('chatInput');
            const box = document.getElementById('chatBox');
            const val = input.value.trim().toLowerCase();
            if (val === "") return;

            isVoiceMode = fromVoice;

            box.innerHTML += `<div class="bubble user-msg">${input.value}</div>`;
            input.value = "";
            box.scrollTop = box.scrollHeight;

            setTimeout(async () => {
                let reply;
                
                if (val.includes("weather")) {
                    const cityMatch = val.match(/weather in (\w+)/);
                    if (cityMatch) {
                        reply = await fetchWeather(cityMatch[1]);
                    } else {
                        const coords = await getCoords();
                        reply = await fetchWeather(coords || "");
                    }
                } 
                else if (val.includes("hi") || val.includes("hello")) reply = aiResponses.greetings[Math.floor(Math.random() * aiResponses.greetings.length)];
                else if (val.includes("how are you")) reply = aiResponses.status[Math.floor(Math.random() * aiResponses.status.length)];
                else if (val.includes("who are you")) reply = aiResponses.identity[Math.floor(Math.random() * aiResponses.identity.length)];
                else if (val.includes("time")) reply = "The time is " + new Date().toLocaleTimeString();
                else reply = aiResponses.default[Math.floor(Math.random() * aiResponses.default.length)];

                box.innerHTML += `<div class="bubble ai-msg">${reply}</div>`;
                box.scrollTop = box.scrollHeight;
                
                if (isVoiceMode) speakText(reply);
            }, 800);
        }

        function handleUnlock() {
            if (document.getElementById('passInput').value === PASS) {
                localStorage.setItem('rt_auth', '1');
                unlockUI();
            } else { alert("ACCESS DENIED!"); }
        }

        function unlockUI() {
            document.getElementById('password-page').classList.remove('section-active');
            document.getElementById('main-profile').classList.add('section-active');
            const h = document.getElementById('appHeader');
            h.style.visibility = 'visible'; h.style.opacity = '1';
        }

        window.onload = () => { if(localStorage.getItem('rt_auth')) unlockUI(); };
    </script>
</body>
</html>
